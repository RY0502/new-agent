# Environment configuration for 1GB RAM systems with virtual memory
# Copy this to .env for low-memory deployments

# Timeout settings (increased for systems with memory swapping)
REQUEST_TIMEOUT=120000
LLM_TIMEOUT=90000
GROQ_TIMEOUT=45000

# Concurrency settings (reduced for low memory)
MAX_CONCURRENT_REQUESTS=1
ENABLE_REQUEST_QUEUE=true

# Logging (reduced to save memory)
LOG_LEVEL=warn
ENABLE_PERFORMANCE_LOGS=false

# Server settings
PORT=8123

# Add your API keys here
# GOOGLE_API_KEY=your_key_here
# ANOTHER_GOOGLE_API_KEY=your_key_here
# MISTRAL_API_KEY=your_key_here
# GROQ_API_KEY=your_key_here
