{
  "catalogId": "chat-agent/custom@1.0.0",
  "components": {
    "Result": {
      "type": "object",
      "description": "A card component for displaying text content, markdown, or general responses",
      "properties": {
        "content": {
          "type": "string",
          "description": "The text or markdown content to display"
        }
      },
      "required": ["content"]
    },
    "List": {
      "type": "object",
      "description": "A bulleted or numbered list component",
      "properties": {
        "items": {
          "type": "array",
          "description": "Array of list items",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["items"]
    },
    "Table": {
      "type": "object",
      "description": "A data table component for displaying tabular data",
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column headers",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "description": "Table rows, each row is an array of values",
          "items": {
            "type": "array",
            "items": {}
          }
        }
      },
      "required": ["columns", "rows"]
    },
    "Tabs": {
      "type": "object",
      "description": "A tabbed view component for organizing content",
      "properties": {
        "tabItems": {
          "type": "array",
          "description": "Array of tab items",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Tab title"
              },
              "content": {
                "type": "string",
                "description": "Tab content"
              }
            },
            "required": ["title", "content"]
          }
        }
      },
      "required": ["tabItems"]
    },
    "Code": {
      "type": "object",
      "description": "A syntax-highlighted code block component",
      "properties": {
        "language": {
          "type": "string",
          "description": "Programming language for syntax highlighting (e.g., python, javascript, typescript)"
        },
        "code": {
          "type": "string",
          "description": "The source code to display"
        }
      },
      "required": ["code"]
    },
    "Video": {
      "type": "object",
      "description": "An embedded video player component for YouTube videos",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the video component"
        },
        "url": {
          "type": "string",
          "description": "YouTube embed URL in format: https://www.youtube.com/embed/VIDEO_ID",
          "pattern": "^https://www\\.youtube\\.com/embed/[A-Za-z0-9_-]{11}$"
        }
      },
      "required": ["id", "url"]
    },
    "Progress": {
      "type": "object",
      "description": "A progress bar component",
      "properties": {
        "label": {
          "type": "string",
          "description": "Label for the progress bar"
        },
        "value": {
          "type": "number",
          "description": "Progress value between 0 and 1",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": ["value"]
    },
    "Image": {
      "type": "object",
      "description": "An image component with responsive sizing and optional fit modes",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the image component"
        },
        "url": {
          "type": "string",
          "description": "Direct HTTPS URL to image file (jpg, png, gif, webp, svg). Must be from reliable sources like Imgur, Flickr, or Reddit."
        },
        "fit": {
          "type": "string",
          "description": "How the image should fit: 'cover' (fills container, may crop), 'contain' (fits entire image), 'fill' (stretches to fill)",
          "enum": ["cover", "contain", "fill"]
        },
        "usageHint": {
          "type": "string",
          "description": "Usage context: 'hero' (large banner), 'thumbnail' (small preview), 'icon' (small icon), 'content' (inline content)",
          "enum": ["hero", "thumbnail", "icon", "content"]
        }
      },
      "required": ["id", "url"]
    },
    "Chart": {
      "type": "object",
      "description": "A chart component for visualizing numeric data. Supports bar, line, area (worm/sparkline for stocks/trends), pie (parts of a whole), and donut (pie with center label).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the chart component"
        },
        "type": {
          "type": "string",
          "description": "Chart type. Use 'bar' for comparing categories (population, revenue per region). Use 'line' for trends over time. Use 'area' (also 'worm') for stock prices, financial time series, or sparkline-style trend lines. Use 'pie' for showing parts of a whole (market share, budget split). Use 'donut' for a pie with a total in the center.",
          "enum": ["bar", "line", "area", "worm", "pie", "donut"]
        },
        "title": {
          "type": "string",
          "description": "Chart title"
        },
        "subtitle": {
          "type": "string",
          "description": "Optional subtitle / context (e.g. unit of measurement, time range)"
        },
        "xLabel": {
          "type": "string",
          "description": "Optional x-axis label"
        },
        "yLabel": {
          "type": "string",
          "description": "Optional y-axis label"
        },
        "data": {
          "type": "array",
          "description": "Series data points",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Data point label"
              },
              "value": {
                "type": "number",
                "description": "Data point value"
              }
            },
            "required": ["label", "value"]
          }
        }
      },
      "required": ["type", "data"]
    },
    "Stat": {
      "type": "object",
      "description": "A grid of KPI / metric cards. Use to present key numbers, scores, or summary figures with optional trend deltas.",
      "properties": {
        "items": {
          "type": "array",
          "description": "List of stat tiles",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "Metric label" },
              "value": { "type": "string", "description": "Headline number/text (e.g. '$1.4B', '82%', '4.7/5')" },
              "delta": { "type": "string", "description": "Change indicator (e.g. '+12%', '-3.2%')" },
              "trend": { "type": "string", "enum": ["up", "down", "flat"], "description": "Trend direction" },
              "sub": { "type": "string", "description": "Optional sub-text under the number" },
              "icon": { "type": "string", "description": "Optional emoji/icon" }
            },
            "required": ["label", "value"]
          }
        }
      },
      "required": ["items"]
    },
    "Timeline": {
      "type": "object",
      "description": "A vertical timeline for events, milestones, history, project phases, etc.",
      "properties": {
        "events": {
          "type": "array",
          "description": "Chronological list of events",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "description": "Time label (e.g. '2024', 'Mar 12', '10:30 AM')" },
              "title": { "type": "string", "description": "Event title" },
              "desc": { "type": "string", "description": "Optional description" },
              "status": { "type": "string", "enum": ["done", "active", "warning", "pending"], "description": "Event status" }
            },
            "required": ["title"]
          }
        }
      },
      "required": ["events"]
    },
    "Callout": {
      "type": "object",
      "description": "An info/success/warning/error/quote box. Use for tips, warnings, key insights, or quotations.",
      "properties": {
        "variant": { "type": "string", "enum": ["info", "success", "warning", "error", "quote"], "description": "Visual style" },
        "heading": { "type": "string", "description": "Optional bold heading" },
        "content": { "type": "string", "description": "Body text" }
      },
      "required": ["variant", "content"]
    },
    "Steps": {
      "type": "object",
      "description": "A numbered step-by-step list. Use for tutorials, processes, or how-to guides.",
      "properties": {
        "current": { "type": "number", "description": "Index of currently active step (0-based, optional)" },
        "steps": {
          "type": "array",
          "description": "Ordered steps",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "Step title" },
              "desc": { "type": "string", "description": "Optional description" },
              "status": { "type": "string", "enum": ["done", "active", "pending"], "description": "Step status" }
            },
            "required": ["title"]
          }
        }
      },
      "required": ["steps"]
    },
    "Badges": {
      "type": "object",
      "description": "A row of colored chips/tags. Use for categories, statuses, technologies, or quick keyword summaries.",
      "properties": {
        "items": {
          "type": "array",
          "description": "Chip list",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "Chip text" },
              "variant": { "type": "string", "enum": ["default", "success", "warning", "error", "info", "muted"], "description": "Color variant" }
            },
            "required": ["label"]
          }
        }
      },
      "required": ["items"]
    }
  },
  "functions": [],
  "theme": {}
}
