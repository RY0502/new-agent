{
  "name": "agent",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=768' npx @langchain/langgraph-cli dev --host 0.0.0.0 --port 8123 --no-browser",
    "dev:low-mem": "NODE_OPTIONS='--max-old-space-size=512' npx @langchain/langgraph-cli dev --host 0.0.0.0 --port 8123 --no-browser",
    "dev:1gb": "NODE_OPTIONS='--max-old-space-size=384 --gc-interval=100' npx @langchain/langgraph-cli dev --host 0.0.0.0 --port 8123 --no-browser",
    "build": "tsc --project tsconfig.json --noEmit",
    "start": "tsx src/server.ts",
    "start:prod": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=512 --gc-interval=100' tsx src/server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "npm@10",
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.13",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@copilotkit/sdk-js": "1.51.4",
    "langchain": "^1.2.3",
    "@langchain/core": "^1.0.1",
    "@langchain/langgraph": "1.0.2",
    "@langchain/langgraph-checkpoint": "1.0.0",
    "@langchain/openai": "^1.1.3",
    "@langchain/mistralai": "^1.0.4",
    "@langchain/google": "^0.1.1",
    "@langchain/groq": "^1.1.1",
    "tsx": "^4.7.1",
    "zod": "^3.23.8"
  }
}
