{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "functions": {
    "api/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/invoke", "dest": "/api/invoke" },
    { "src": "/health", "dest": "/api/health" },
    { "src": "/metrics", "dest": "/api/metrics" }
  ]
}
